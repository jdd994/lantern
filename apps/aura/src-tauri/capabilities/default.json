{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Core UI plus outbound HTTP to Hue's discovery service and any LAN bridge.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "https://discovery.meethue.com/" },
        { "url": "https://*/" },
        { "url": "http://*/" }
      ]
    }
  ]
}
