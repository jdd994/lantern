# Security headers for Cloudflare Pages. This file is copied verbatim into the
# build output and applied to every response.
#
# The Content-Security-Policy is deliberately strict: Driftless is fully
# self-contained, so nothing here loads or talks to a third party. 'self' for
# scripts and connections means an injected or tampered <script>, or any
# attempt to exfiltrate a passphrase/entry to another origin, is blocked by the
# browser. When sync is added, add the API origin to connect-src (and nothing
# else).
/*
  Content-Security-Policy: default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self'; connect-src 'self' https://driftless-server.jdd994.workers.dev; manifest-src 'self'; worker-src 'self'; object-src 'none'; base-uri 'self'; frame-ancestors 'none'; form-action 'none'; upgrade-insecure-requests
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: no-referrer
  Permissions-Policy: camera=(), microphone=(), geolocation=(), interest-cohort=()
  Cross-Origin-Opener-Policy: same-origin
