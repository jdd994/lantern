{
  "name": "ballast",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Steady footing with your money. Local-first, end-to-end encrypted financial wellbeing dashboard.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
