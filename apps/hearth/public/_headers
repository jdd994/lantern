# Security headers, applied to every response. The CSP is deliberately strict:
# Hearth is fully self-contained, so nothing loads or talks to a third party.
#
# `connect-src` — the food/nutrient database is BUNDLED (tier 0, offline), so the
# app talks to exactly two hosts, both deliberate:
#   1. our own sync server — opaque ciphertext + non-secret metadata only (never
#      the passphrase or the key);
#   2. world.openfoodfacts.org — tier 1 barcode lookup (added 2026-07-16). The
#      honest cost: OFF learns *a barcode was looked up*, plus an IP. It never
#      learns who you are or anything about your day, and what comes back is
#      stored encrypted like any other food. Disclosed in the UI where you scan.
# Never an analytics host; there is no analytics, and nothing that could ever see
# what someone eats.
/*
  Content-Security-Policy: default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self'; connect-src 'self' https://hearth-server.jdd994.workers.dev https://world.openfoodfacts.org; manifest-src 'self'; worker-src 'self'; object-src 'none'; base-uri 'self'; frame-ancestors 'none'; form-action 'none'; upgrade-insecure-requests
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: no-referrer
  Permissions-Policy: camera=(), microphone=(), geolocation=(), interest-cohort=(), payment=()
  Cross-Origin-Opener-Policy: same-origin
